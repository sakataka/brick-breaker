{
  "name": "brick-breaker-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "preview": "bunx vite preview",
    "test": "bun test",
    "e2e": "bunx playwright test",
    "e2e:ci": "PLAYWRIGHT_WEB_SERVER_COMMAND='bun run preview --host 127.0.0.1 --port 4173' bunx playwright test",
    "typecheck": "bunx tsc --noEmit -p tsconfig.app.json && bunx tsc --noEmit -p tsconfig.test.json",
    "lint": "bunx biome check .",
    "deadcode": "knip --include files,dependencies,devDependencies,unlisted,binaries,unresolved --exclude exports,types",
    "deadcode:report": "knip --exclude types --no-exit-code --reporter compact",
    "check:fast": "bun run typecheck && bun run lint && bun run deadcode && bun test",
    "guard:local": "bun run check:fast",
    "refactor:audit": "bun run scripts/refactor-audit.ts",
    "check:arch": "depcruise --config .dependency-cruiser.cjs src",
    "verify:change-coverage": "bun run scripts/verify-change-coverage.ts",
    "guard:ci": "bun run check && bun test && bun run e2e:ci",
    "scaffold:feature": "bun run scripts/scaffold-feature.ts",
    "prepare": "lefthook install",
    "format": "bunx biome format --write .",
    "check": "bun run typecheck && bun run lint && bun run deadcode && bun run build",
    "typesafe-i18n": "typesafe-i18n"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tone": "^15.1.22",
    "ts-pattern": "^5.9.0",
    "typesafe-i18n": "^5.27.1",
    "xstate": "^5.28.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "dependency-cruiser": "^17.3.8",
    "knip": "^5.85.0",
    "lefthook": "^2.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
