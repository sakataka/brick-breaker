{
  "name": "brick-breaker-local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "e2e": "playwright test",
    "e2e:ci": "PLAYWRIGHT_WEB_SERVER_COMMAND='VITE_BRICK_BREAKER_TEST_BRIDGE=1 vp build && vp preview --host 127.0.0.1 --port 4173' playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.node.json",
    "typecheck:ts7": "pnpm exec tsgo --noEmit -p tsconfig.app.json && pnpm exec tsgo --noEmit -p tsconfig.test.json && pnpm exec tsgo --noEmit -p tsconfig.node.json",
    "deadcode": "knip --include files,dependencies,devDependencies,unlisted,binaries,unresolved --exclude exports,types",
    "deadcode:report": "knip --exclude types --no-exit-code --reporter compact",
    "check:arch": "depcruise --config .dependency-cruiser.cjs src",
    "guard:test-state-shape": "node scripts/guard-test-state-shape.mjs",
    "guard:ai-first-boundaries": "node scripts/guard-ai-first-boundaries.mjs",
    "verify:change-coverage": "node scripts/verify-change-coverage.mjs",
    "scaffold:feature": "node scripts/scaffold-feature.mjs",
    "prepare": "vp config",
    "typesafe-i18n": "typesafe-i18n"
  },
  "dependencies": {
    "@fontsource/public-sans": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "motion": "^12.38.0",
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tone": "^15.1.22",
    "typesafe-i18n": "^5.27.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260323.1",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.3.9",
    "knip": "^6.0.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plus": "0.1.11"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.11.0",
  "knip": {
    "ignoreFiles": [
      "src/types/culori.d.ts"
    ],
    "ignoreDependencies": [
      "@typescript/native-preview"
    ],
    "ignoreBinaries": [
      "tsgo"
    ]
  }
}
