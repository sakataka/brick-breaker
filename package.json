{
  "name": "brick-breaker-local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.node.json",
    "e2e": "playwright test",
    "e2e:ci": "PLAYWRIGHT_WEB_SERVER_COMMAND='VITE_BRICK_BREAKER_TEST_BRIDGE=1 bun run build && bun run preview -- --host 127.0.0.1 --port 4173' playwright test",
    "scaffold:feature": "bun scripts/scaffold-feature.mjs",
    "typesafe-i18n": "typesafe-i18n"
  },
  "dependencies": {
    "@fontsource/public-sans": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "motion": "^12.38.0",
    "phaser": "^4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tone": "^15.1.22",
    "typesafe-i18n": "^5.27.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.13"
}
